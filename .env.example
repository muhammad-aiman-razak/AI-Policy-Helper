# Backend — LLM
LLM_PROVIDER=stub                # options: stub | openrouter | ollama
LLM_MODEL=openai/gpt-4o-mini     # model name for OpenRouter
OPENROUTER_API_KEY=               # required if LLM_PROVIDER=openrouter
OLLAMA_HOST=http://ollama:11434   # Ollama server URL
OLLAMA_MODEL=llama3.2             # Ollama model (must be pulled first)

# Backend — Embeddings & Vector Store
EMBEDDING_MODEL=local-384         # hash-based local embedder
VECTOR_STORE=qdrant               # options: qdrant | memory
COLLECTION_NAME=policy_helper
CHUNK_SIZE=700                    # words per chunk
CHUNK_OVERLAP=80                  # word overlap between chunks

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
